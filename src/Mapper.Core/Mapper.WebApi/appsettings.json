{
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=MapperDB;Username=postgres;Password=pass"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowAnyOriginInDevelopment": false,
    "AllowedOrigins": []
  },
  "StartupTasks": {
    "ApplyMigrations": false,
    "SeedDatabase": false,
    "EnsureS3Bucket": false,
    "MigrateAttempts": 10
  },
  "Redis": { "ConnectionString": "" },

  "S3": {
    "ServiceUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": ""
  },

  "Elastic": { "Url": "" },

  "Seq": { "ServerUrl": "" },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },

  "Otel": { "Endpoint": "" },
  "Retention": {
    "ArchiveCleanup": {
      "Enabled": false,
      "Cron": "0 3 * * *",
      "MotionVideoRetentionDays": 90,
      "NoMotionVideoRetentionDays": 7,
      "ArchivedVideoRetentionDays": 365,
      "Take": 100,
      "DryRun": true,
      "Confirm": false
    }
  },
  "Camera": {
    "FfmpegPath": "",
    "Jobs": {
      "MotionCron": "*/5 * * * *",
      "VideoCron": "*/30 * * * *",
      "StatusCron": "*/1 * * * *",
      "SnapshotCron": "*/1 * * * *"
    }
  }
}
