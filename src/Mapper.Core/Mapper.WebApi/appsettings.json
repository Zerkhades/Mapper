{
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=MapperDB;Username=postgres;Password=pass"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "InitializeOnStart": true,
  "Redis": { "ConnectionString": "redis:6379" },

  "S3": {
    "ServiceUrl": "http://minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "mapper"
  },

  "Elastic": { "Url": "http://elasticsearch:9200" },

  "Seq": { "ServerUrl": "http://seq:80" },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:80"
        }
      }
    ]
  },

  "Otel": { "Endpoint": "http://jaeger:4317" }
}
