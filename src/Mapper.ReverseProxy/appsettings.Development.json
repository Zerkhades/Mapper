{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api": {
        "ClusterId": "api",
        "Match": { "Path": "/api/{**catch-all}" },
        "Order": 10,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "swagger": {
        "ClusterId": "api",
        "Match": { "Path": "/swagger/{**catch-all}" },
        "Order": 20,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "swagger-ui": {
        "ClusterId": "api",
        "Match": { "Path": "/" },
        "Order": 30,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "swagger-assets": {
        "ClusterId": "api",
        "Match": { "Path": "/swagger-ui/{**catch-all}" },
        "Order": 31,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "swagger-index": {
        "ClusterId": "api",
        "Match": { "Path": "/index.html" },
        "Order": 32,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "swagger-oauth-callback": {
        "ClusterId": "api",
        "Match": { "Path": "/oauth2-redirect.html" },
        "Order": 33,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "hangfire": {
        "ClusterId": "api",
        "Match": { "Path": "/hangfire/{**catch-all}" },
        "Order": 40,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "hangfire-root": {
        "ClusterId": "api",
        "Match": { "Path": "/hangfire" },
        "Order": 41,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "hubs": {
        "ClusterId": "api",
        "Match": { "Path": "/hubs/{**catch-all}" },
        "Order": 50,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "metrics": {
        "ClusterId": "api",
        "Match": { "Path": "/metrics" },
        "Order": 60,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "api-health": {
        "ClusterId": "api",
        "Match": { "Path": "/health/ready" },
        "Order": 70,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Order": 80,
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      }
    },
    "Clusters": {
      "api": { "Destinations": { "d1": { "Address": "http://mapper.webapi:5001/" } } },
      "auth": { "Destinations": { "d1": { "Address": "http://keycloak:8080/" } } }
    }
  }
}


