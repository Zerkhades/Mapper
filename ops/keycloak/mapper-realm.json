{
  "realm": "mapper",
  "enabled": true,
  "displayName": "Mapper",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "roles": {
    "realm": [
      {
        "name": "mapper-user",
        "description": "Default Mapper API user"
      },
      {
        "name": "mapper-admin",
        "description": "Mapper administrator"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "api",
      "description": "Mapper API access",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "mapper.swagger",
      "name": "Mapper Swagger UI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:5001/swagger/oauth2-redirect.html",
        "http://localhost:5001/oauth2-redirect.html",
        "https://localhost:7193/swagger/oauth2-redirect.html",
        "http://localhost:8080/swagger/oauth2-redirect.html",
        "https://localhost:8081/swagger/oauth2-redirect.html",
        "http://localhost:8080/oauth2-redirect.html",
        "https://localhost:8081/oauth2-redirect.html"
      ],
      "webOrigins": [
        "http://localhost:5001",
        "https://localhost:7193",
        "http://localhost:8080",
        "https://localhost:8081"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "api"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "mapper.client",
      "name": "Mapper service client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "mapper-client-dev-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "profile",
        "roles",
        "email",
        "api"
      ]
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "mapper.admin",
      "email": "mapper.admin@example.local",
      "firstName": "Mapper",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": [
        "mapper-user",
        "mapper-admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "mapper-admin",
          "temporary": false
        }
      ]
    }
  ]
}
